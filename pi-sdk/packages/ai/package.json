{
	"name": "@earendil-works/pi-ai",
	"version": "0.75.5",
	"description": "Unified LLM API with automatic model discovery and provider configuration",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./anthropic": {
			"types": "./src/providers/anthropic.ts",
			"import": "./src/providers/anthropic.ts"
		},
		"./azure-openai-responses": {
			"types": "./src/providers/azure-openai-responses.ts",
			"import": "./src/providers/azure-openai-responses.ts"
		},
		"./google": {
			"types": "./src/providers/google.ts",
			"import": "./src/providers/google.ts"
		},
		"./google-vertex": {
			"types": "./src/providers/google-vertex.ts",
			"import": "./src/providers/google-vertex.ts"
		},
		"./mistral": {
			"types": "./src/providers/mistral.ts",
			"import": "./src/providers/mistral.ts"
		},
		"./openai-codex-responses": {
			"types": "./src/providers/openai-codex-responses.ts",
			"import": "./src/providers/openai-codex-responses.ts"
		},
		"./openai-completions": {
			"types": "./src/providers/openai-completions.ts",
			"import": "./src/providers/openai-completions.ts"
		},
		"./openai-responses": {
			"types": "./src/providers/openai-responses.ts",
			"import": "./src/providers/openai-responses.ts"
		},
		"./oauth": {
			"types": "./src/oauth.ts",
			"import": "./src/oauth.ts"
		},
		"./bedrock-provider": {
			"types": "./src/bedrock-provider.ts",
			"import": "./src/bedrock-provider.ts"
		}
	},
	"bin": {
		"pi-ai": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"generate-models": "node scripts/generate-models.ts",
		"generate-image-models": "node scripts/generate-image-models.ts",
		"build": "npm run generate-models && npm run generate-image-models && tsgo -p tsconfig.build.json",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "0.91.1",
		"@aws-sdk/client-bedrock-runtime": "3.1048.0",
		"@smithy/node-http-handler": "4.7.3",
		"@google/genai": "1.52.0",
		"@mistralai/mistralai": "2.2.1",
		"http-proxy-agent": "7.0.2",
		"https-proxy-agent": "7.0.6",
		"openai": "6.26.0",
		"partial-json": "0.1.7",
		"typebox": "1.1.38"
	},
	"keywords": [
		"ai",
		"llm",
		"openai",
		"anthropic",
		"gemini",
		"bedrock",
		"unified",
		"api"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/earendil-works/pi-mono.git",
		"directory": "packages/ai"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"canvas": "3.2.3",
		"vitest": "3.2.4"
	}
}
