node_modules/
.pi/auth.json
.env
dist/
build/
.DS_Store
node_modules
nul

# Agent session data and test traces (keep directory structure)
.pi/agent/sessions/*
!.pi/agent/sessions/.gitkeep

# Wiki database and concepts network (keep directory structure)
wiki_core/concepts/*
!wiki_core/concepts/.gitkeep
wiki_core/temporary/*
!wiki_core/temporary/.gitkeep
wiki_core/archive/*
!wiki_core/archive/.gitkeep

# QQ Bot Logger output
inbox/qq-logs/

# NapCat QQ Bot runtime caches, databases, logs, and account-specific settings
napcat/*.db*
napcat/*.log
napcat/napcat/config/napcat_*.json
napcat/napcat/config/napcat_protocol_*.json
napcat/napcat/config/onebot11_*.json

# Ignore NapCat large executables, DLLs, and Node native addons
napcat/**/*.exe
napcat/**/*.dll
napcat/**/*.node
